# Ignore everything
*

# But not these directories
!extra_data/
!predictions/

# Ignore everything inside these directories
extra_data/*
predictions/*

# But allow CSV files inside them
!extra_data/*.csv
!predictions/*.csv

# Allow app.R
!app.R

# Allow R directory and files
!R/
!R/*.R

# Allow www directory and files
!www/
!www/*.css

# Allow .gitignore
!.gitignore
